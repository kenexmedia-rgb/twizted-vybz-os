{
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/monthly-reset",
      "schedule": "0 0 1 * *"
    },
    {
      "path": "/api/cron/budget-warning",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/enforce-budgets",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/daily-summary",
      "schedule": "0 1 * * *"
    }
  ]
}
